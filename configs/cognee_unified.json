{
  "name": "cognee",
  "description": "Complete Cognee knowledge base - open-source framework for building knowledge graphs and RAG pipelines. Combines official documentation with GitHub codebase insights for data ingestion, graph construction, vector stores, LLM integration, custom pipelines, deployment, and API usage.",
  "merge_mode": "rule-based",
  "sources": [
    {
      "type": "documentation",
      "base_url": "https://docs.cognee.ai/",
      "extract_api": true,
      "selectors": {
        "main_content": "article",
        "title": "h1",
        "code_blocks": "pre"
      },
      "url_patterns": {
        "include": [],
        "exclude": ["/changelog", "?", "#"]
      },
      "categories": {
        "getting_started": ["getting-started", "introduction", "quickstart", "installation"],
        "core_concepts": ["core-concepts", "building-blocks", "datapoints", "knowledge-graph", "pipelines"],
        "configuration": ["setup", "configuration", "config", "permissions", "vector", "graph-store"],
        "guides": ["guides", "examples", "tutorials", "custom-tasks", "custom-pipelines"],
        "deployment": ["deploy", "self-hosting", "ec2", "kubernetes", "modal", "cloud"],
        "integrations": ["integrations", "llm-providers", "observability", "evaluation", "agents", "mcp"],
        "api": ["api-reference", "http-api", "python-api", "auth", "datasets", "search"]
      },
      "rate_limit": 0.3,
      "max_pages": 300
    },
    {
      "type": "github",
      "repo": "topoteretes/cognee",
      "include_issues": true,
      "max_issues": 150,
      "include_changelog": true,
      "include_releases": true,
      "include_code": true,
      "code_analysis_depth": "deep",
      "file_patterns": [
        "cognee/**/*.py",
        "cognee/api/**/*.py",
        "cognee/modules/**/*.py",
        "cognee/tasks/**/*.py",
        "cognee/infrastructure/**/*.py",
        "examples/**/*.py",
        "docs/**/*.md",
        "*.md"
      ]
    }
  ]
}
